<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOS Darurat"
        android:textColor="#D32F2F"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Kirim titik koordinat lokasi darurat via SMS ke kerabat terdekat"
        android:textColor="#757575"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Nomor Kontak Darurat (HP):"
        android:textColor="#212121"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNomorDarurat"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF"
        android:hint="Contoh: 08123456789"
        android:inputType="phone"
        android:paddingLeft="16dp" />

    <Button
        android:id="@+id/btnSimpanNomor"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#1976D2"
        android:text="Simpan / Edit Nomor"
        android:textColor="#FFFFFF" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:background="#E0E0E0" />

    <Button
        android:id="@+id/btnKirimSOS"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:backgroundTint="#D32F2F"
        android:text="KIRIM SOS\nDARURAT"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />
</LinearLayout>