<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OCR Reader"
        android:textColor="#1976D2"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Foto teks dokumen untuk didengar lewat suara"
        android:textColor="#757575"
        android:textSize="14sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvHasilOCR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hasil teks OCR akan muncul disini..."
                android:textColor="#212121"
                android:textSize="16sp" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnAmbilFoto"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#1976D2"
        android:text="Ambil Foto"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnBacakanOCR"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FFFFFF"
        android:text="Bacakan Hasil"
        android:textColor="#1976D2" />
</LinearLayout>