<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speech To Text"
        android:textColor="#1976D2"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ubah ucapan suara langsung menjadi teks tulisan"
        android:textColor="#757575"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <TextView
            android:id="@+id/tvHasilSuara"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:text="Tekan tombol mikrofon di bawah dan mulailah berbicara..."
            android:textColor="#000000"
            android:textSize="18sp"
            android:background="#FFFFFF" />
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnMulaiBicara"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:backgroundTint="#1976D2"
        android:text="Tekan &amp; Bicara"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>